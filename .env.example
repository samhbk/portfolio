# ─── Vercel deploy ───────────────────────────────────────────────────────────
# In the Vercel dashboard: Project → Settings → Environment Variables.
#
# NEXT_PUBLIC_SITE_URL — canonical site URL for metadata, sitemap, robots.
#   Set for Production only (e.g. https://your-domain.com) so Preview deployments
#   keep using VERCEL_URL automatically. Optional if you only use *.vercel.app.
#
# VERCEL_URL — set by Vercel at build/runtime; do not add manually.
#
# Contact API (optional — without RESEND_API_KEY the form opens the visitor’s mail app)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Portfolio <onboarding@resend.dev>
# CONTACT_TO_EMAIL=you@example.com
#
# In-repo fallbacks: src/lib/resendContactConfig.ts
